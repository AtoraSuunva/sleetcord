{
  "name": "sleetcord",
  "version": "4.3.0",
  "description": "An interaction-first command library for Discord.js",
  "license": "MIT",
  "author": "AtoraSuunva",
  "repository": {
    "type": "git",
    "url": "https://github.com/AtoraSuunva/sleetcord"
  },
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "scripts": {
    "start:dev": "vp exec tsx -r dotenv/config test/index.ts",
    "build": "vp pack",
    "check": "vp check",
    "fix": "vp check --fix",
    "prepublishOnly": "vp check && vp pack",
    "publish:npm": "vp pm publish",
    "publish:jsr": "vp exec jsr publish"
  },
  "dependencies": {
    "discord-api-types": "^0.38.47",
    "tseep": "^1.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "7.0.0-dev.20260424.2",
    "dotenv": "^17.4.2",
    "env-var": "^7.5.0",
    "jsr": "0.14.3",
    "tsx": "^4.21.0",
    "vite-plus": "^0.1.24"
  },
  "peerDependencies": {
    "discord.js": "^14.26.2"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.7.0"
}
