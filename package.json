{
  "name": "sleetcord",
  "version": "4.0.0",
  "description": "An interaction-first command library for Discord.js",
  "license": "MIT",
  "author": "AtoraSuunva",
  "repository": {
    "type": "git",
    "url": "https://github.com/AtoraSuunva/sleetcord"
  },
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "start:dev": "tsx -r dotenv/config test/index.ts",
    "build": "tsdown",
    "check": "pnpm run '/.*:check/'",
    "fix": "pnpm run '/.*:fix/'",
    "lint:check": "oxlint",
    "format:check": "oxfmt --check",
    "lint:fix": "oxlint --fix",
    "format:fix": "oxfmt --write",
    "prepublishOnly": "pnpm check && pnpm build",
    "publish:npm": "pnpm publish",
    "publish:jsr": "pnpx jsr publish"
  },
  "dependencies": {
    "discord-api-types": "^0.38.45",
    "tseep": "^1.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "7.0.0-dev.20260410.1",
    "dotenv": "^17.4.1",
    "env-var": "^7.5.0",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.20.0",
    "tsdown": "^0.21.7",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "discord.js": "^14.26.2"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.33.0"
}
