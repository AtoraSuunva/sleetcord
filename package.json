{
  "name": "sleetcord",
  "version": "3.0.0",
  "description": "An interaction-first command library for Discord.js",
  "license": "MIT",
  "author": "AtoraSuunva",
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    "import": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "start:dev": "tsx -r dotenv/config test/index.ts",
    "build": "tsdown",
    "check": "pnpm run '/.*:check/'",
    "fix": "pnpm run '/.*:fix/'",
    "lint:check": "oxlint",
    "format:check": "oxfmt --check",
    "lint:fix": "oxlint --fix",
    "format:fix": "oxfmt --write",
    "prepublishOnly": "pnpm check && pnpm build"
  },
  "dependencies": {
    "discord-api-types": "^0.38.20",
    "tseep": "^1.3.1"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@typescript/native-preview": "7.0.0-dev.20260407.1",
    "dotenv": "^17.2.1",
    "env-var": "^7.5.0",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.20.0",
    "tsdown": "^0.14.1",
    "tsx": "^4.20.4",
    "typescript": "^5.9.2"
  },
  "peerDependencies": {
    "discord.js": "^14.22.0"
  }
}
